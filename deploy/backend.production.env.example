# Copy to backend/.env on the server

DATABASE_URL="postgresql://tracker:STRONG_PASSWORD@localhost:5432/tracker"
PORT=3001

TRACKER_BASE_URL="https://track.arthome.ai"
TRACKER_SERVER_IP="YOUR_VPS_IP"
TRACKER_DNS_MODE="cname_root"
TRACKER_DOMAIN_PROTOCOL="https"

ADMIN_API_KEY="generate-a-long-random-key"
CORS_ORIGIN="*"
ALLOW_TEST_IP_OVERRIDE=false
