DATABASE_URL="postgresql://tracker:tracker@localhost:5433/tracker"
PORT=3001
TRACKER_BASE_URL="http://localhost:3001"
# Custom domains DNS mode:
# cname_root (default) — CNAME track → your root domain (when root A already points to server)
# a — separate A record on track subdomain
TRACKER_DNS_MODE="cname_root"
# Optional comma-separated DNS resolvers for domain verification (defaults to Google + Cloudflare)
TRACKER_DNS_SERVERS="8.8.8.8,1.1.1.1"
TRACKER_CNAME_TARGET=""
TRACKER_SERVER_IP="76.13.114.85"
TRACKER_DOMAIN_PROTOCOL="https"
ADMIN_API_KEY="dev-api-key-change-me"
# Mediago S2S postback — account name from Mediago dashboard (required for conversion test to show ✓)
MEDIAGO_ACCOUNT_NAME=""
# Use * to allow LP script calls from any landing page domain
CORS_ORIGIN="*"
# Local dev only: allow ?__test_ip=109.52.221.77 on click URLs to simulate real geo/IP
ALLOW_TEST_IP_OVERRIDE=true
